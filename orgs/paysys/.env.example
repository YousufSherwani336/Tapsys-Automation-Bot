# ── Org ────────────────────────────────────────────────────────────────────────
ORG=paysys

# ── LLM / Pi Agent ─────────────────────────────────────────────────────────────
# Provider: anthropic (default) | openai | github-copilot | openrouter | etc.
# Model:    claude-sonnet-4-20250514 (default)
PI_MODEL_PROVIDER=anthropic
PI_MODEL_NAME=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── OPENMMS SQL Server (read-only credentials ONLY) ────────────────────────────
# DB_OPENMMS_ENGINE is accepted for compatibility but IGNORED by this Node.js project.
# This project uses the Node `mssql` (tedious) driver — no pymssql/Python.
DB_OPENMMS_ENGINE=mssql+pymssql
DB_OPENMMS_HOST=192.168.196.9
DB_OPENMMS_PORT=1440
DB_OPENMMS_NAME=OPENMMS
DB_OPENMMS_USER=sreuser
DB_OPENMMS_PASS=

# ── Query safety ───────────────────────────────────────────────────────────────
DB_TRUST_CERT=true
DB_QUERY_TIMEOUT_SECONDS=30
DB_MAX_ROWS=500

# ── WhatsApp ───────────────────────────────────────────────────────────────────
# MUST be true during testing. Only set false after confirming on real device.
WHATSAPP_DRY_RUN=true

# ── Reports ────────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=output/reports
REPORT_TIMEZONE=Asia/Karachi

# ── Memory ─────────────────────────────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_DB_PATH=data/memory.sqlite

# ── Audit Logging ──────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=logs/audit.log
